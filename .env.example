# Example Supabase environment variables
# Set these in Lovable Cloud (or your hosting provider) and in GitHub/Vercel preview secrets.

# Project URL (e.g. https://<project>.supabase.co)
SUPABASE_URL=

# Client publishable / anon key (either name is accepted)
SUPABASE_PUBLISHABLE_KEY=
# or
SUPABASE_ANON_KEY=

# Server-side service role key (trusted; DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional Vite-prefixed values for preview builds (used on client-side builds)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Helpful: set the same values as project secrets for preview/staging deployments
